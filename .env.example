# ============================================================
# 将本文件复制为 .env，并填入真实配置
# cp .env.example .env
# ============================================================

# DeepSeek API（与 OpenAI SDK 兼容）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 消息推送 - 方案A: PushPlus (微信)
PUSHPLUS_TOKEN=your_pushplus_token_here

# 消息推送 - 方案B: 飞书/钉钉 Webhook
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxx
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxxx

# 数据库路径（默认 data/myfund.db）
DATABASE_URL=sqlite:///data/myfund.db

# 日志级别（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO
