# MyFund-Quant-System .gitignore

# ── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
*.so

# ── 虚拟环境 ────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── 环境变量（含 API Key，绝对不能提交！）─────────────────
.env

# ── 数据库文件（本地私有数据）─────────────────────────────
data/*.db
data/*.db-shm
data/*.db-wal

# ── 日志 ────────────────────────────────────────────────────
logs/

# ── IDE ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── macOS ────────────────────────────────────────────────────
.DS_Store

# ── Alembic 自动生成的迁移版本（视情况决定是否提交）─────────
# alembic/versions/

# ── 临时输出文件 ────────────────────────────────────────────
out*.txt
output.csv
streamlit_debug.log
scratch/*.log

# ── 临时补丁/测试脚本 ──────────────────────────────────────
patch_*.py
fix_*.py
test_*.py
clean_icons.py

# ── 二进制/工具包 ──────────────────────────────────────────
*.zip
*.tar.gz
uv-x86_64-unknown-linux-gnu/

# ── 本地历史净值缓存（可重新下载）─────────────────────────
data/*.csv
data/*.json
